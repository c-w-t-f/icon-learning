---
import Button from "../primitives/Button.astro";

interface Cta {
  label: string;
  href: string;
}

interface Props {
  heading: string;
  sub: string;
  primaryCta: Cta;
  secondaryCta: Cta;
}

const { heading, sub, primaryCta, secondaryCta } = Astro.props;
---

<section id="contact-cta" class="section-pad bg-[var(--color-surface-muted)]">
  <div class="container-page">
    <div class="mx-auto max-w-[45rem] rounded-[20px] border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-10 text-center shadow-[var(--shadow-sm)] sm:p-12">
      <p class="eyebrow justify-center">Start a conversation</p>
      <h2 class="display-lg mt-4 text-balance">{heading}</h2>
      <p class="body-lg mx-auto mt-5 max-w-[42rem] text-[var(--color-ink-muted)]">{sub}</p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <Button href={primaryCta.href} size="lg">{primaryCta.label}</Button>
        <Button href={secondaryCta.href} variant="outline" size="lg">{secondaryCta.label}</Button>
      </div>
    </div>
  </div>
</section>

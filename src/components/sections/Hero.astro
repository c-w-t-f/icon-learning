---
import Button from "../primitives/Button.astro";

interface Cta {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  headline: string;
  sub: string;
  primaryCta: Cta;
  secondaryCta: Cta;
  backgroundImage?: string;
}

const { eyebrow, headline, sub, primaryCta, secondaryCta, backgroundImage } = Astro.props;
const heroStyle = backgroundImage ? `--photo-hero-image: url("${backgroundImage}");` : undefined;
---

<section
  id="hero"
  class:list={[
    "hero-section container-page flex min-h-[78vh] flex-col items-center justify-center gap-7 pb-[clamp(3rem,6vw,5rem)] pt-[calc(var(--nav-height)+clamp(5rem,9vw,8rem))] text-center",
    { "photo-hero": backgroundImage },
  ]}
  style={heroStyle}
>
  {eyebrow && <p class="eyebrow" data-hero-item>{eyebrow}</p>}
  <h1 class="display-xl max-w-4xl text-balance" data-hero-item>{headline}</h1>
  <p class="body-lg max-w-[38ch] text-[var(--color-ink-muted)]" data-hero-item>{sub}</p>
  <div class="flex flex-col gap-3 sm:flex-row" data-hero-item>
    <Button href={primaryCta.href} size="lg">{primaryCta.label}</Button>
    <Button href={secondaryCta.href} variant="outline" size="lg">{secondaryCta.label}</Button>
  </div>
</section>

<style>
  .hero-section {
    background: var(--color-bg);
  }
</style>

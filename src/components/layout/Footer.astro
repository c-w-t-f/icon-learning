---
import { footerGroups } from "../../content/navigation";
import { site } from "../../content/site";
---

<footer class="border-t border-[var(--color-border-strong)] bg-[var(--color-bg)]">
  <div class="container-wide grid gap-10 py-12 lg:grid-cols-[1.4fr_2fr]">
    <div class="max-w-sm">
      <a class="flex items-center gap-3 font-bold" href="/" aria-label={`${site.name} home`}>
        <span class="grid h-9 w-9 place-items-center rounded-full bg-[var(--color-ink)] text-sm text-[var(--color-ink-inverse)]">IL</span>
        <span>{site.name}</span>
      </a>
      <p class="body-sm mt-5 text-[var(--color-ink-muted)]">
        Practical corporate training, ISO consultancy, and in-house learning support for Malaysian teams.
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-3">
      {
        footerGroups.map((group) => (
          <div>
            <h2 class="eyebrow">{group.title}</h2>
            <ul class="mt-4 space-y-3">
              {group.links.map((link) => (
                <li>
                  <a class="body-sm text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-ink)]" href={link.href}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="container-wide flex flex-col gap-3 border-t border-[var(--color-border)] py-6 text-sm text-[var(--color-ink-muted)] sm:flex-row sm:items-center sm:justify-between">
    <p>Copyright {new Date().getFullYear()} {site.name}. All rights reserved.</p>
    <a class="hover:text-[var(--color-ink)]" href="https://astro.build/">Made with Astro</a>
  </div>
</footer>
